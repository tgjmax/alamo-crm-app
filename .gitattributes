# Normalize line endings: store text as LF in the repo and check out LF everywhere,
# so Windows checkouts stop triggering "LF will be replaced by CRLF" churn.
* text=auto eol=lf

# Keep these as-is on any platform.
*.sh text eol=lf

# Binary assets — never normalize or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
